{
  "name": "suka",
  "version": "0.1.0",
  "description": "Native Pi-powered personal assistant daemon with Telegram, web, scheduler, and Postgres memory.",
  "type": "module",
  "license": "MIT",
  "main": "runtime/src/index.ts",
  "bin": {
    "suka": "runtime/src/index.ts"
  },
  "files": [
    "runtime/src",
    "runtime/web/static",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run runtime/src/index.ts",
    "dev": "bun --watch runtime/src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "bun run typecheck && bun run lint",
    "db:migrate": "bun run runtime/src/db/migrate.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.5",
    "@earendil-works/pi-ai": "0.75.5",
    "@earendil-works/pi-coding-agent": "0.75.5",
    "grammy": "1.38.0",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  },
  "x-dependency-policy": "Pinned exact versions only (no ^/~ ranges)."
}
